{
  "name": "aihackason",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:server": "pnpm -F @aihackason/server dev",
    "dev:client": "pnpm -F @aihackason/client dev",
    "dev": "concurrently -n server,client -c blue,green \"pnpm dev:server\" \"pnpm dev:client\"",
    "build:client": "pnpm -F @aihackason/client build",
    "db:generate": "pnpm -F @aihackason/server db:generate",
    "db:migrate:local": "pnpm -F @aihackason/server db:migrate:local",
    "db:migrate:remote": "pnpm -F @aihackason/server db:migrate:remote",
    "deploy": "pnpm build:client && pnpm -F @aihackason/server deploy",
    "lint": "oxlint --deny-warnings .",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "typecheck": "pnpm -F @aihackason/client typecheck && pnpm -F @aihackason/server typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0"
  },
  "packageManager": "pnpm@10.12.1"
}
